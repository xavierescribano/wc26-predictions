generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  PLAYER
}

enum PhaseType {
  GROUP_STAGE
  ROUND_OF_32
  ROUND_OF_16
  QUARTERFINALS
  SEMIFINALS
  FINAL
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  role          Role      @default(PLAYER)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  groupPredictions GroupPrediction[]
  knockoutPicks    KnockoutPick[]
  goldenPick       GoldenPick?
  sentInvites      Invite[]          @relation("InviteSender")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Invite {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique @default(cuid())
  senderId  String
  sender    User      @relation("InviteSender", fields: [senderId], references: [id])
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model Team {
  id        String  @id @default(cuid())
  name      String
  shortCode String  @unique
  group     String
  flagEmoji String?

  homeMatches  Match[] @relation("HomeTeam")
  awayMatches  Match[] @relation("AwayTeam")
  wonMatches   Match[] @relation("Winner")

  position1Predictions GroupPrediction[] @relation("Position1")
  position2Predictions GroupPrediction[] @relation("Position2")
  position3Predictions GroupPrediction[] @relation("Position3")
  position4Predictions GroupPrediction[] @relation("Position4")

  knockoutPicks KnockoutPick[]
  goldenPicks   GoldenPick[]

  groupResult1 GroupResult[] @relation("GroupResult1")
  groupResult2 GroupResult[] @relation("GroupResult2")
  groupResult3 GroupResult[] @relation("GroupResult3")
  groupResult4 GroupResult[] @relation("GroupResult4")
}

model Phase {
  id       String    @id @default(cuid())
  type     PhaseType @unique
  isOpen   Boolean   @default(false)
  order    Int
  openedAt DateTime?
  closedAt DateTime?

  matches Match[]
}

model Match {
  id          String    @id @default(cuid())
  phaseId     String
  matchNumber Int
  homeTeamId  String?
  awayTeamId  String?
  homeScore   Int?
  awayScore   Int?
  winnerId    String?
  matchDate   DateTime?
  description String?

  phase         Phase          @relation(fields: [phaseId], references: [id])
  homeTeam      Team?          @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam      Team?          @relation("AwayTeam", fields: [awayTeamId], references: [id])
  winner        Team?          @relation("Winner", fields: [winnerId], references: [id])
  knockoutPicks KnockoutPick[]
}

model GroupResult {
  id          String @id @default(cuid())
  groupLetter String @unique
  position1Id String
  position2Id String
  position3Id String
  position4Id String

  position1 Team @relation("GroupResult1", fields: [position1Id], references: [id])
  position2 Team @relation("GroupResult2", fields: [position2Id], references: [id])
  position3 Team @relation("GroupResult3", fields: [position3Id], references: [id])
  position4 Team @relation("GroupResult4", fields: [position4Id], references: [id])
}

model GroupPrediction {
  id           String   @id @default(cuid())
  userId       String
  groupLetter  String
  position1Id  String
  position2Id  String
  position3Id  String
  position4Id  String
  pointsEarned Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  position1 Team @relation("Position1", fields: [position1Id], references: [id])
  position2 Team @relation("Position2", fields: [position2Id], references: [id])
  position3 Team @relation("Position3", fields: [position3Id], references: [id])
  position4 Team @relation("Position4", fields: [position4Id], references: [id])

  @@unique([userId, groupLetter])
}

model KnockoutPick {
  id                 String   @id @default(cuid())
  userId             String
  matchId            String
  pickedTeamId       String
  predictedHomeScore Int?
  predictedAwayScore Int?
  isCorrect          Boolean?
  pointsEarned       Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match      Match @relation(fields: [matchId], references: [id])
  pickedTeam Team  @relation(fields: [pickedTeamId], references: [id])

  @@unique([userId, matchId])
}

model GoldenPick {
  id           String   @id @default(cuid())
  userId       String   @unique
  teamId       String
  changes      Int      @default(0)
  isCorrect    Boolean?
  pointsEarned Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id])
}
